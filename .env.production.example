# ============================================
# HRMS Web Application — Production Environment
# ============================================
# Copy this file to .env and fill in all values.
# DO NOT commit the .env file to version control.
# ============================================

# ---- General ----
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ---- Database (PostgreSQL) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://hrms_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/hrms_db?schema=public

# ---- JWT Authentication ----
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET_KEY
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_STRONG_SECRET_KEY
JWT_REFRESH_EXPIRES_IN=30d

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- CORS ----
# Comma-separated list of allowed origins (your frontend URL)
CORS_ORIGIN=https://your-domain.com

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ---- Logging ----
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Email (SMTP) — Optional ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@your-domain.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@your-domain.com

# ---- Redis — Optional (for session store / caching) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Frontend (Vite) ----
# These are prefixed with VITE_ so Vite exposes them to the client bundle.
VITE_API_BASE_URL=https://api.your-domain.com/api
VITE_APP_NAME=HRMSLite
VITE_APP_VERSION=1.0.0
