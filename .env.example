# ============================================
# HRMS Web Application - Environment Variables
# ============================================
# Copy this file to .env and update the values
# cp .env.example .env

# ---- General ----
NODE_ENV=development

# ---- Backend Server ----
PORT=5000
HOST=0.0.0.0

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hrms_db
DB_USER=hrms_user
DB_PASSWORD=hrms_password
DATABASE_URL=postgresql://hrms_user:hrms_password@localhost:5432/hrms_db?schema=public

# ---- JWT Authentication ----
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- CORS ----
CORS_ORIGIN=http://localhost:5173

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=HRMSLite

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ---- Email (Optional - for notifications) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@hrms.com

# ---- Redis (Optional - for caching/sessions) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Logging ----
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
